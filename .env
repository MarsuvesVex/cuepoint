API_PORT=8088
API_ADDR=:8088
API_BASE_URL=http://127.0.0.1:8088
BOT_API_BASE_URL=http://127.0.0.1:8088
CLI_API_BASE_URL=http://127.0.0.1:8088

POSTGRES_PORT=5439
PGADMIN_PORT=5054
REDIS_PORT=6378
REDISINSIGHT_PORT=5541

DATABASE_URL=postgres://cuepoint:cuepoint@127.0.0.1:5439/cuepoint?sslmode=disable
REDIS_ADDR=127.0.0.1:6378
REDIS_DB=0

WORKER_POLL_INTERVAL=5s
WORKER_BLOCK_TIMEOUT=5s
QUEUE_NAME=cuepoint:jobs

TRAEFIK_ENABLED=true
TRAEFIK_NETWORK=reverse-proxy-docker-traefik_routing
TRAEFIK_ENTRYPOINT=web
TRAEFIK_TLS=false
PGADMIN_DEFAULT_EMAIL=admin@cuepoint.app
PGADMIN_HOST=pgadmin-cuepoint.dev.local
REDISINSIGHT_HOST=redisinsight-cuepoint.dev.local
